# ── Jupyter Notebook Checkpoints ────────────────────────────
.ipynb_checkpoints/
*/.ipynb_checkpoints/

# ── Python Cache ─────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd

# ── Virtual Environment ──────────────────────────────────────
venv/
env/
.env
.venv/

# ── OS Files ─────────────────────────────────────────────────
.DS_Store           # Mac
Thumbs.db           # Windows
desktop.ini

# ── Data Files (if large) ────────────────────────────────────
# Uncomment below if your dataset is large (>50MB)
# data/raw/*.csv
# data/processed/*.csv

# ── HTML Reports (auto-generated, no need to push) ───────────
reports/*.html

# ── Images (optional — keep if you want them on GitHub) ──────
# images/*.png

# ── Editor / IDE Settings ────────────────────────────────────
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# ── Logs & Temp Files ────────────────────────────────────────
*.log
*.tmp
*.temp
*.swp

# ── Build / Dist ─────────────────────────────────────────────
dist/
build/
*.egg-info/